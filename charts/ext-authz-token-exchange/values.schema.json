{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "ext-authz-token-exchange values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string"
        }
      }
    },
    "deployments": {
      "type": "object",
      "additionalProperties": true
    },
    "deploymentAnnotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "serviceAccountName": {
      "type": "string",
      "minLength": 1
    },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "securityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "env": {
      "type": "object",
      "additionalProperties": true
    },
    "ports": {
      "type": "object",
      "additionalProperties": true
    },
    "livenessProbe": {
      "type": "object",
      "additionalProperties": true
    },
    "readinessProbe": {
      "type": "object",
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "additionalProperties": true
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "ports": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "oauth": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "createSecret": {
          "type": "boolean"
        },
        "secretName": {
          "type": "string",
          "minLength": 1
        },
        "clientID": {
          "type": "string"
        },
        "clientSecret": {
          "type": "string"
        },
        "existingSecret": {
          "type": "object",
          "additionalProperties": true,
          "required": ["name", "clientIDKey", "clientSecretKey"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "clientIDKey": {
              "type": "string",
              "minLength": 1
            },
            "clientSecretKey": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "serviceAccountName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "envoyFilter": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "timeout": {
          "type": "string",
          "minLength": 1
        },
        "workloadSelectorLabels": {
          "type": "object"
        },
        "workloadSelectorLabelsOverride": {
          "type": "object"
        }
      }
    },
    "authorizationPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "providerName": {
          "type": "string",
          "minLength": 1
        },
        "workloadSelectorLabels": {
          "type": "object"
        },
        "workloadSelectorLabelsOverride": {
          "type": "object"
        },
        "rules": {
          "type": "array"
        }
      }
    },
    "gatewayExtAuthzService": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "externalName": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        },
        "targetPort": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "appProtocol": {
          "type": "string",
          "minLength": 1
        },
        "serviceEntry": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "location": {
              "type": "string",
              "minLength": 1
            },
            "resolution": {
              "type": "string",
              "minLength": 1
            },
            "protocol": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string",
          "minLength": 1
        },
        "scrapeTimeout": {
          "type": "string",
          "minLength": 1
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "grafanaDashboard": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "datasourceUid": {
          "type": "string",
          "minLength": 1
        },
        "pluginJob": {
          "type": "string",
          "minLength": 1
        },
        "gatewayJob": {
          "type": "string",
          "minLength": 1
        },
        "gatewayWorkload": {
          "type": "string",
          "minLength": 1
        },
        "providerCluster": {
          "type": "string"
        },
        "envoyTimeoutMs": {
          "type": "number"
        },
        "tokenEndpointTimeoutSeconds": {
          "type": "number"
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "ext-authz-token-exchange values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "oauth": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "createSecret": {
          "type": "boolean"
        },
        "secretName": {
          "type": "string",
          "minLength": 1
        },
        "clientID": {
          "type": "string"
        },
        "clientSecret": {
          "type": "string"
        },
        "existingSecret": {
          "type": "object",
          "additionalProperties": true,
          "required": ["name", "clientIDKey", "clientSecretKey"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "clientIDKey": {
              "type": "string",
              "minLength": 1
            },
            "clientSecretKey": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "tokenExchange": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "defaultTokenEndpoint": {
          "type": "string"
        },
        "tokenEndpointAllowlist": {
          "type": "string"
        },
        "bearerRealm": {
          "type": "string",
          "minLength": 1
        },
        "allowUnauthenticatedOptions": {
          "type": "boolean"
        },
        "defaultDenyUnmatched": {
          "type": "boolean"
        },
        "httpClient": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "requestTimeout": {
              "type": "string",
              "minLength": 1
            },
            "dialTimeout": {
              "type": "string",
              "minLength": 1
            },
            "tlsHandshakeTimeout": {
              "type": "string",
              "minLength": 1
            },
            "responseHeaderTimeout": {
              "type": "string",
              "minLength": 1
            },
            "idleConnTimeout": {
              "type": "string",
              "minLength": 1
            },
            "maxIdleConns": {
              "type": "integer",
              "minimum": 0
            },
            "maxIdleConnsPerHost": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "serviceAccountName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "envoyFilter": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "timeout": {
          "type": "string",
          "minLength": 1
        },
        "workloadSelectorLabels": {
          "type": "object"
        },
        "workloadSelectorLabelsOverride": {
          "type": "object"
        }
      }
    },
    "service": {
      "type": "object"
    }
  }
}

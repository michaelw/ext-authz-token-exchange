{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "keycloak values",
  "type": "object",
  "additionalProperties": true,
  "required": ["namespace", "pluginNamespace", "keycloak", "clients", "secret", "testUser"],
  "properties": {
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "pluginNamespace": {
      "type": "string",
      "minLength": 1
    },
    "gatewayProvider": {
      "type": "string",
      "enum": ["local-istio", "gke-gateway"]
    },
    "gkeGatewayNamespace": {
      "type": "string",
      "minLength": 1
    },
    "keycloak": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "image", "port", "realm"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "image": {
          "type": "object",
          "additionalProperties": true,
          "required": ["repository"],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "pullPolicy": {
              "type": "string"
            }
          }
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "externalHost": {
          "type": "string",
          "minLength": 1
        },
        "externalURL": {
          "type": "string",
          "minLength": 1
        },
        "realm": {
          "type": "string",
          "minLength": 1
        },
        "strategy": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string"
            }
          }
        }
      }
    },
    "clients": {
      "type": "object",
      "additionalProperties": true,
      "required": ["subject", "shortTTLSubject", "exchanger", "audience"]
    },
    "secret": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "clientIDKey", "clientSecretKey"]
    },
    "gateway": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "sectionName": {
          "type": "string"
        },
        "httpRedirect": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "sectionName": {
              "type": "string"
            }
          }
        }
      }
    },
    "gkeIap": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "protection": {
          "type": "string"
        },
        "policyName": {
          "type": "string"
        },
        "oauthClientID": {
          "type": "string"
        },
        "oauthClientSecret": {
          "type": "string"
        },
        "secretName": {
          "type": "string"
        }
      }
    },
    "gkeHealthCheck": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "requestPath": {
          "type": "string"
        },
        "checkIntervalSec": {
          "type": "integer"
        },
        "timeoutSec": {
          "type": "integer"
        },
        "healthyThreshold": {
          "type": "integer"
        },
        "unhealthyThreshold": {
          "type": "integer"
        },
        "logConfig": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "testUser": {
      "type": "object",
      "additionalProperties": true,
      "required": ["username", "password"]
    }
  }
}

{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Automerge Renovate version bumps after required CI passes",
      "matchManagers": [
        "gomod",
        "github-actions",
        "pre-commit"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "enabled": true
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "enabled": true
    },
    {
      "matchManagers": [
        "pre-commit"
      ],
      "enabled": true
    }
  ]
}
